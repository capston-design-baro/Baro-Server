# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/baro_db

# Security Keys
SECRET_KEY=your-secret-key-here-min-32-characters-change-this
ENCRYPTION_KEY=your-base64-encoded-encryption-key-generate-new-one

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini

# Baro-AI Service URL
BARO_AI_URL=http://localhost:8001

# AWS S3 Configuration (Optional - for future chat archiving)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=baro-conversations
# AWS_REGION=ap-northeast-2

# CORS Configuration (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com